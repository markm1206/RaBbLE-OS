# {{ ansible_managed }}
# /etc/default/grub — RaBbLE Grub2 configuration
# Managed by ansible — edit ansible/inventory/group_vars/all.yml to change values

GRUB_TIMEOUT={{ rabble_grub_timeout | default(3) }}
GRUB_DEFAULT={{ rabble_grub_default | default(0) }}
GRUB_TIMEOUT_STYLE=menu

# HiDPI graphics mode — set native res, fall back to auto
GRUB_GFXMODE={{ rabble_gfx_mode | default('auto') }}
GRUB_GFXPAYLOAD_LINUX={{ rabble_grub_gfxpayload | default('keep') }}

# Theme
GRUB_THEME=/boot/grub2/themes/rabble/theme.txt
GRUB_BACKGROUND=/boot/grub2/themes/rabble/background.png

# Kernel command line
GRUB_CMDLINE_LINUX="rhgb quiet \
  rd.plymouth=1 \
  plymouth.enable=1 \
  loglevel=3 \
  udev.log_level=3 \
  systemd.show_status=auto \
  fbcon=nodefer \
  {{ rabble_grub_extra_cmdline | default('') }}"

GRUB_CMDLINE_LINUX_DEFAULT=""

# Misc
GRUB_DISABLE_RECOVERY=false
GRUB_DISABLE_SUBMENU=false
GRUB_ENABLE_BLSCFG=true
