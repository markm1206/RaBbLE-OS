# {{ ansible_managed }}
# /etc/os-release — RaBbLE-OS system identity
#
# GRUB reads PRETTY_NAME from this file to label boot menu entries.
# ID and VERSION_ID must stay as fedora/{{ rabble_fedora_version }} for DNF, RPM,
# and Fedora module stream compatibility. Everything else is ours.
#
# To distinguish multiple installs in GRUB, set rabble_epoch_name in
# ansible/inventory/host_vars/localhost.yml before running the playbook.

NAME="{{ rabble_os_name }}"
PRETTY_NAME="{{ rabble_os_pretty_name }}"
ID=fedora
ID_LIKE=fedora
VERSION="{{ rabble_fedora_version }} ({{ rabble_os_variant }})"
VERSION_ID={{ rabble_fedora_version }}
PLATFORM_ID="platform:f{{ rabble_fedora_version }}"
VARIANT="{{ rabble_os_variant }}"
VARIANT_ID=rabble
ANSI_COLOR="1;35"
HOME_URL="{{ rabble_os_home_url }}"
SUPPORT_URL="{{ rabble_os_home_url }}/issues"
BUG_REPORT_URL="{{ rabble_os_home_url }}/issues"
LOGO=fedora-logo-icon
