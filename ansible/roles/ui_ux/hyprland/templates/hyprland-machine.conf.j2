# {{ ansible_managed }}
# ~/.config/hypr/machine.conf
# Machine-specific overrides — generated by ansible, NOT symlinked.
# Edit ansible/inventory/group_vars/<target>.yml to change these values.
# Hand-edit this file only for temporary local tweaks.

# ── Monitor configuration ─────────────────────────────────────────────────────
# Format: monitor=<name>,<resolution>@<hz>,<position>,<scale>
monitor={{ rabble_hypr_monitor | default(',preferred,auto,1') }}
monitor={{ rabble_hypr_monitor_fallback | default(',preferred,auto,1') }}

# ── Cursor size (HiDPI) ───────────────────────────────────────────────────────
env = XCURSOR_SIZE,{{ 24 * rabble_hidpi_scale | int }}
env = HYPRCURSOR_SIZE,{{ 24 * rabble_hidpi_scale | int }}

# ── XWayland DPI ─────────────────────────────────────────────────────────────
xwayland {
    force_zero_scaling = {{ 'true' if rabble_hidpi_scale | int > 1 else 'false' }}
}
