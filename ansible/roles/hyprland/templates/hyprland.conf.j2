# ╔══════════════════════════════════════════════════════════╗
# ║  RaBbLE-OS — Hyprland Configuration                      ║
# ║  Generated by Ansible — edit via dotfiles/ in repo       ║
# ║  Hardware: ASUS ProArt P16 / AMD 890M + NVIDIA RTX 4060  ║
# ╚══════════════════════════════════════════════════════════╝

# ─── Monitors ────────────────────────────────────────────────────
# ProArt P16 internal display: 2560x1600 @ 165Hz
monitor = eDP-1, 2560x1600@165, 0x0, 1.6
# External monitors: auto-detect
monitor = ,preferred,auto,1

# ─── Environment Variables ───────────────────────────────────────
# AMD iGPU drives Wayland — NVIDIA available via PRIME
env = GBM_BACKEND,radeonsi
env = __GLX_VENDOR_LIBRARY_NAME,mesa
env = LIBVA_DRIVER_NAME,radeonsi
env = WLR_DRM_DEVICES,/dev/dri/card1:/dev/dri/card0
# Qt Wayland
env = QT_QPA_PLATFORM,wayland
env = QT_WAYLAND_DISABLE_WINDOWDECORATION,1
env = QT_AUTO_SCREEN_SCALE_FACTOR,1
# XWayland scaling
env = XCURSOR_SIZE,24
# Electron/Chromium
env = ELECTRON_OZONE_PLATFORM_HINT,wayland
env = NIXOS_OZONE_WL,1

# ─── Startup ─────────────────────────────────────────────────────
exec-once = /usr/lib/polkit-kde-authentication-agent-1
exec-once = hyprpaper
exec-once = hypridle
exec-once = mako
exec-once = waybar  # Replace with quickshell when built

# ─── Input ───────────────────────────────────────────────────────
input {
    kb_layout = us
    follow_mouse = 1
    touchpad {
        natural_scroll = true
        disable_while_typing = true
        tap-to-click = true
        scroll_factor = 0.5
    }
    sensitivity = -0.3
}

# ─── General ─────────────────────────────────────────────────────
general {
    gaps_in = 6
    gaps_out = 12
    border_size = 1
    # Active border: magenta → cyan gradient
    col.active_border = rgba(ff2d78ff) rgba(00f5ffff) 45deg
    # Inactive border: muted violet
    col.inactive_border = rgba(2a0060aa)
    layout = dwindle
    resize_on_border = true
}

# ─── Decoration ──────────────────────────────────────────────────
decoration {
    rounding = 6
    active_opacity = 1.0
    inactive_opacity = 0.92

    blur {
        enabled = true
        size = 8
        passes = 2
        new_optimizations = true
        xray = false
        noise = 0.02
        contrast = 0.9
        brightness = 0.8
        popups = true
    }

    drop_shadow = true
    shadow_range = 20
    shadow_render_power = 3
    # Shadow color: neon magenta glow
    col.shadow = rgba(ff2d7866)
    col.shadow_inactive = rgba(0a001099)
}

# ─── Animations ──────────────────────────────────────────────────
animations {
    enabled = true

    # Custom bezier curves — snappy but smooth
    bezier = rabble_in,   0.05, 0.9,  0.1,  1.05
    bezier = rabble_out,  0.3,  0.0,  0.8,  0.0
    bezier = rabble_inout,0.87, 0.0,  0.13, 1.0
    bezier = neon_pulse,  0.0,  0.85, 0.0,  1.0

    animation = windows,     1, 4,  rabble_in,    slide
    animation = windowsOut,  1, 3,  rabble_out,   slide
    animation = windowsMove, 1, 4,  rabble_inout
    animation = border,      1, 8,  default
    animation = borderangle, 1, 60, default,      loop
    animation = fade,        1, 4,  rabble_inout
    animation = workspaces,  1, 5,  rabble_inout, slide
    animation = specialWorkspace, 1, 5, neon_pulse, slidevert
}

# ─── Layout ──────────────────────────────────────────────────────
dwindle {
    pseudotile = true
    preserve_split = true
    force_split = 2
}

master {
    new_status = master
}

# ─── Gestures (touchpad) ─────────────────────────────────────────
gestures {
    workspace_swipe = true
    workspace_swipe_fingers = 3
    workspace_swipe_distance = 300
    workspace_swipe_invert = true
    workspace_swipe_cancel_ratio = 0.3
}

# ─── Misc ────────────────────────────────────────────────────────
misc {
    force_default_wallpaper = 0   # Disable Hyprland anime wallpaper
    disable_hyprland_logo = true
    disable_splash_rendering = true
    vfr = true                    # Variable framerate — good for laptop battery
    mouse_move_enables_dpms = true
    animate_manual_resizes = true
}

# ─── Window Rules ────────────────────────────────────────────────
# Float small utility windows
windowrulev2 = float, class:(pavucontrol)
windowrulev2 = float, class:(nm-connection-editor)
windowrulev2 = float, class:(org.kde.polkit-kde-authentication-agent-1)
windowrulev2 = float, title:(Picture-in-Picture)
windowrulev2 = pin,   title:(Picture-in-Picture)
# Fix XWayland blur artifacts
windowrulev2 = noblur, xwayland:1

# ─── Keybindings ─────────────────────────────────────────────────
$mod = SUPER
$terminal = kitty
$launcher = wofi --show drun

# Core
bind = $mod, Return, exec, $terminal
bind = $mod, Space,  exec, $launcher
bind = $mod, Q,      killactive
bind = $mod SHIFT, E, exit
bind = $mod, F, fullscreen
bind = $mod SHIFT, F, togglefloating
bind = $mod, P, pseudo
bind = $mod, T, togglesplit

# Focus
bind = $mod, H, movefocus, l
bind = $mod, L, movefocus, r
bind = $mod, K, movefocus, u
bind = $mod, J, movefocus, d

# Move windows
bind = $mod SHIFT, H, movewindow, l
bind = $mod SHIFT, L, movewindow, r
bind = $mod SHIFT, K, movewindow, u
bind = $mod SHIFT, J, movewindow, d

# Workspaces 1-10
bind = $mod, 1, workspace, 1
bind = $mod, 2, workspace, 2
bind = $mod, 3, workspace, 3
bind = $mod, 4, workspace, 4
bind = $mod, 5, workspace, 5
bind = $mod, 6, workspace, 6
bind = $mod, 7, workspace, 7
bind = $mod, 8, workspace, 8
bind = $mod, 9, workspace, 9
bind = $mod, 0, workspace, 10

bind = $mod SHIFT, 1, movetoworkspace, 1
bind = $mod SHIFT, 2, movetoworkspace, 2
bind = $mod SHIFT, 3, movetoworkspace, 3
bind = $mod SHIFT, 4, movetoworkspace, 4
bind = $mod SHIFT, 5, movetoworkspace, 5

# Screenshots
bind = ,      Print, exec, grim ~/Pictures/screenshot-$(date +%s).png
bind = SHIFT, Print, exec, grim -g "$(slurp)" ~/Pictures/screenshot-$(date +%s).png

# Audio (ASUS ProArt P16 laptop keys)
bindel = , XF86AudioRaiseVolume,  exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindel = , XF86AudioLowerVolume,  exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindel = , XF86AudioMute,         exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle
# Brightness (ASUS)
bindel = , XF86MonBrightnessUp,   exec, brightnessctl set 10%+
bindel = , XF86MonBrightnessDown, exec, brightnessctl set 10%-

# Mouse bindings
bindm = $mod, mouse:272, movewindow
bindm = $mod, mouse:273, resizewindow
