# RaBbLE-OS Snapper home policy
# Applied to: /home (Btrfs subvolume 'home', ID 257)
# More conservative — home data changes less critically
SUBVOLUME="/home"
FSTYPE="btrfs"

ALLOW_USERS="{{ rabble_user }}"
ALLOW_GROUPS=""
SYNC_ACL="no"

BACKGROUND_COMPARISON="yes"
NUMBER_CLEANUP="yes"
NUMBER_MIN_AGE="1800"
NUMBER_LIMIT="20"
NUMBER_LIMIT_IMPORTANT="5"

TIMELINE_CREATE="yes"
TIMELINE_CLEANUP="yes"
TIMELINE_MIN_AGE="1800"
TIMELINE_LIMIT_HOURLY="3"
TIMELINE_LIMIT_DAILY="7"
TIMELINE_LIMIT_WEEKLY="2"
TIMELINE_LIMIT_MONTHLY="3"
TIMELINE_LIMIT_YEARLY="1"

EMPTY_PRE_POST_CLEANUP="yes"
EMPTY_PRE_POST_MIN_AGE="1800"
